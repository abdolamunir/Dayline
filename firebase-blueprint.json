{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "doing", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "areaId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["title", "status", "priority", "uid"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "active", "completed", "paused"] },
        "deadline": { "type": "string" },
        "goalId": { "type": "string" },
        "taskIds": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["name", "status", "uid"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A high-level goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "progress": { "type": "number" },
        "targetDate": { "type": "string" },
        "areaId": { "type": "string" },
        "projectIds": { "type": "array", "items": { "type": "string" } },
        "taskIds": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["title", "progress", "uid"]
    },
    "Area": {
      "title": "Area",
      "description": "A life area",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "goalIds": { "type": "array", "items": { "type": "string" } },
        "projectIds": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["name", "uid"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A recurring habit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "streak": { "type": "number" },
        "logs": { "type": "object" },
        "goalId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "frequency", "streak", "uid"]
    },
    "Note": {
      "title": "Note",
      "description": "A user note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "projectId": { "type": "string" },
        "ideaIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "status": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "content", "createdAt", "status", "uid"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals"
    },
    "/areas/{areaId}": {
      "schema": "Area",
      "description": "User areas"
    },
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habits"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    }
  }
}
