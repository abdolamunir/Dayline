rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Fields: title (string), description (string), status (string), priority (string), dueDate (string), startTime (string), endTime (string), uid (string)
    //
    // Collection: projects
    // Fields: name (string), status (string), uid (string)
    //
    // Collection: goals
    // Fields: title (string), progress (number), uid (string)
    //
    // Collection: areas
    // Fields: name (string), uid (string)
    //
    // Collection: habits
    // Fields: name (string), frequency (string), streak (number), uid (string)
    //
    // Collection: notes
    // Fields: title (string), content (string), tags (list), projectId (string), ideaIds (list), createdAt (string), status (string), uid (string)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() < 50)) &&
             (!('startTime' in data) || (data.startTime is string && data.startTime.size() < 50)) &&
             (!('endTime' in data) || (data.endTime is string && data.endTime.size() < 50)) &&
             (!('projectId' in data) || (data.projectId is string && data.projectId.size() < 100)) &&
             (!('goalId' in data) || (data.goalId is string && data.goalId.size() < 100)) &&
             (!('areaId' in data) || (data.areaId is string && data.areaId.size() < 100)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() < 20)) &&
             data.status in ['todo', 'doing', 'done'] &&
             data.priority in ['low', 'medium', 'high'] &&
             data.uid == request.auth.uid;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.status in ['planning', 'active', 'completed', 'paused'] &&
             data.uid == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.uid == request.auth.uid;
    }

    function isValidArea(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid == request.auth.uid;
    }

    function isValidHabit(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.frequency in ['daily', 'weekly'] &&
             data.streak is number && data.streak >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidNote(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.content is string && data.content.size() < 10000 &&
             (!('tags' in data) || (data.tags is list && data.tags.size() < 20)) &&
             (!('projectId' in data) || (data.projectId is string && data.projectId.size() < 100)) &&
             (!('ideaIds' in data) || (data.ideaIds is list && data.ideaIds.size() < 50)) &&
             data.createdAt is string &&
             data.status is string &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidProject(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /goals/{goalId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidGoal(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidGoal(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /areas/{areaId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidArea(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidArea(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /habits/{habitId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHabit(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidHabit(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidNote(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
